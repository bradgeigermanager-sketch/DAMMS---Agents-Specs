
```yaml
system:
  id: damms_unified_system_v16
  version: 16
  description: >
    Fully integrated multi-layer DAMMS architecture including I/O, domain specialists,
    core cognition, meta-reasoning, meta-learning, derivation, generalization,
    tagging/ontology, schema/code/db engineering, library lifecycle, skill/workflow
    infrastructure, memory governance, communication protocols, research intelligence,
    and global governance/oversight.

  layers:
    - id: io_and_systems_layer
      order: 1
      role: io_systems
      description: External interfaces, APIs, web, files, sensors, actuators, cloud, scheduling.
      agents:
        - api_interaction_agent
        - web_navigation_agent
        - file_system_agent
        - database_query_agent
        - sensor_interface_agent
        - actuator_control_agent
        - environment_simulation_agent
        - network_operations_agent
        - cloud_orchestration_agent
        - scheduler_cron_agent

    - id: dialogue_and_social_layer
      order: 2
      role: interaction
      description: Dialogue, negotiation, persuasion, empathy, social reasoning, and conversation summarization.
      agents:
        - dialogue_agent
        - negotiation_agent
        - persuasion_agent
        - empathy_agent
        - social_norms_agent
        - multi_agent_coordinator
        - persona_simulation_agent
        - feedback_interpretation_agent
        - social_reasoning_agent
        - conversation_summarizer_agent

    - id: core_cognitive_layer
      order: 3
      role: cognition
      description: Working memory, long-term memory, attention, inference, meta-cognition, and learning strategy.
      agents:
        - working_memory_agent
        - long_term_memory_agent
        - attention_control_agent
        - meta_cognition_agent
        - cognitive_load_manager
        - schema_builder_agent
        - concept_formation_agent
        - inference_engine_agent
        - cognitive_consistency_agent
        - learning_strategy_agent

    - id: meta_reasoning_and_self_debug_layer
      order: 4
      role: meta_reasoning
      description: Self-repair, trace analysis, error localization, assumption checking, consistency and regression control.
      agents:
        - self_repair_agent
        - trace_analyzer_agent
        - error_localization_agent
        - assumption_checker_agent
        - redundancy_checker_agent
        - consistency_debugger_agent
        - regression_detection_agent
        - self_evaluation_agent
        - hypothesis_tester_agent
        - debugging_orchestrator_agent

    - id: meta_learning_layer
      order: 5
      role: meta_learning
      description: How the system learns, sequences tasks, acquires skills, tracks performance, and generalizes.
      agents:
        - meta_learning_agent
        - curriculum_designer_agent
        - skill_acquisition_agent
        - knowledge_gap_detector
        - adaptive_strategy_agent
        - performance_tracking_agent
        - experience_replay_agent
        - generalization_agent
        - self_optimization_agent
        - learning_orchestrator_agent

    - id: communication_protocol_layer
      order: 6
      role: communication_protocol
      description: Message formatting, protocol translation, routing, context sync, and multi-channel coordination.
      agents:
        - message_formatting_agent
        - protocol_translation_agent
        - semantic_alignment_agent
        - conversation_routing_agent
        - handshake_negotiation_agent
        - protocol_compliance_agent
        - error_resilient_messaging_agent
        - context_synchronization_agent
        - multi_channel_communication_agent
        - protocol_orchestrator_agent

    - id: research_intelligence_layer
      order: 7
      role: research_intelligence
      description: Research planning, retrieval, validation, evidence ranking, contradiction detection, and uncertainty.
      agents:
        - research_planning_agent
        - information_retrieval_agent
        - source_credibility_agent
        - cross_verification_agent
        - data_quality_agent
        - evidence_ranking_agent
        - bias_detection_agent
        - claim_validation_agent
        - data_provenance_agent
        - research_summarization_agent
        - contradiction_detection_agent
        - uncertainty_estimation_agent
        - research_workflow_agent
        - data_validation_orchestrator

    - id: derivation_and_inductive_construction_layer
      order: 8
      role: derivation
      description: Pattern extraction, rule synthesis, tool/workflow derivation, schema induction, algorithm discovery.
      agents:
        - pattern_extraction_agent
        - rule_synthesis_agent
        - tool_derivation_agent
        - workflow_derivation_agent
        - data_driven_heuristic_agent
        - schema_induction_agent
        - algorithm_discovery_agent
        - meta_pattern_agent
        - abstraction_agent
        - data_driven_toolchain_agent

    - id: generalization_and_template_induction_layer
      order: 9
      role: generalization
      description: Task abstraction, template synthesis, process generalization, task-to-skill conversion, cross-domain patterns.
      agents:
        - task_abstraction_agent
        - template_synthesis_agent
        - process_generalization_agent
        - task_pattern_matcher
        - reusable_component_extractor
        - task_to_skill_converter
        - generalization_mapping_agent
        - template_evolution_agent
        - cross_domain_pattern_agent
        - generalization_orchestrator

    - id: tagging_metadata_ontology_layer
      order: 10
      role: tagging
      description: Content/process/template tagging, domain/use-case mapping, ontology linking, metadata enrichment.
      agents:
        - content_tagging_agent
        - process_tagging_agent
        - template_tagging_agent
        - file_type_classification_agent
        - codec_identification_agent
        - schema_tagging_agent
        - domain_mapping_agent
        - use_case_tagging_agent
        - metadata_enrichment_agent
        - tag_consistency_agent
        - ontology_linking_agent
        - tagging_orchestrator_agent

    - id: schema_code_database_engineering_layer
      order: 11
      role: schema_engineering
      description: Schema design/evolution, code generation/refactoring, DB modeling/optimization, migrations, API schemas.
      agents:
        - schema_design_agent
        - schema_evolution_agent
        - database_modeling_agent
        - query_construction_agent
        - code_generation_agent
        - code_refactoring_agent
        - process_to_code_agent
        - schema_validation_agent
        - database_integrity_agent
        - code_dependency_agent
        - migration_planning_agent
        - api_schema_agent
        - codec_mapping_agent
        - tool_construction_agent
        - codebase_governance_agent
        - schema_driven_workflow_agent
        - database_optimization_agent
        - code_testing_agent
        - schema_tool_orchestrator

    - id: library_lifecycle_version_governance_layer
      order: 12
      role: library_lifecycle
      description: Versioning, maintenance, deprecation, update propagation, compatibility, indexing, releases, rollback.
      agents:
        - version_control_agent
        - library_maintenance_agent
        - deprecation_manager_agent
        - update_propagation_agent
        - compatibility_checker_agent
        - library_indexing_agent
        - change_impact_analyzer
        - release_manager_agent
        - rollback_agent
        - library_governance_agent

    - id: skill_workflow_tooling_infrastructure_layer
      order: 13
      role: skill_infrastructure
      description: Skill libraries, loaders, workflow templates, tool registries, toolchains, skill/workflow optimization.
      agents:
        - skill_library_agent
        - skill_loader_agent
        - workflow_template_agent
        - tool_registry_agent
        - tool_selection_agent
        - toolchain_builder_agent
        - skill_evolution_agent
        - workflow_optimization_agent
        - library_governance_agent   # shared governance role

    - id: memory_governance_layer
      order: 14
      role: memory_governance
      description: Memory policy, integrity, permissions, audit, conflict resolution, versioning, hygiene, provenance, alignment.
      agents:
        - memory_policy_agent
        - memory_integrity_agent
        - memory_permissioning_agent
        - memory_audit_agent
        - memory_conflict_resolver
        - memory_versioning_agent
        - memory_hygiene_agent
        - memory_provenance_agent
        - memory_alignment_agent
        - memory_governance_orchestrator

- id: governance_and_oversight_layer
      order: 15
      role: governance
      description: >
        Global safety, ethics, legal compliance, risk, permissions, bias detection,
        accountability, and moral-legal orchestration.
      agents:
        # existing high-level governance agents
        - oversight_agent
        - audit_trail_agent
        - risk_assessment_agent
        - ethics_review_agent
        - compliance_agent
        - permissioning_agent
        - governance_orchestrator
        - bias_detection_agent
        - accountability_agent

        # moral–legal sub-layer agents
        - moral_reasoning_agent
        - legal_compliance_agent
        - ethical_constraint_agent
        - harm_detection_agent
        - intent_verification_agent
        - moral_consistency_agent
        - legal_risk_assessment_agent
        - policy_enforcement_agent      # now explicitly scoped as moral/legal + platform policy
        - output_sanitization_agent
        - moral_legal_audit_agent
        - behavior_authorization_agent
        - ethical_legal_orchestrator

    - id: governance_and_oversight_layer
      order: 15
      role: governance
      description: Global safety, ethics, compliance, risk, permissions, bias detection, accountability, audit, governance orchestration.
      agents:
        - policy_enforcement_agent
        - oversight_agent
        - audit_trail_agent
        - risk_assessment_agent
        - ethics_review_agent
        - compliance_agent
        - permissioning_agent
        - governance_orchestrator
        - bias_detection_agent
        - accountability_agent

  cross_layer_contracts:
    - id: research_to_memory_contract
      description: Validated research outputs must pass memory governance checks before being written to long-term memory.
      producers:
        - research_workflow_agent
        - data_validation_orchestrator
      consumers:
        - memory_policy_agent
        - memory_provenance_agent
        - memory_alignment_agent

    - id: schema_to_tooling_contract
      description: Schema changes propagate to code, tools, and workflows via orchestrated updates with compatibility checks.
      producers:
        - schema_evolution_agent
        - schema_tool_orchestrator
      consumers:
        - code_generation_agent
        - tool_construction_agent
        - toolchain_builder_agent
        - update_propagation_agent
        - compatibility_checker_agent

    - id: tagging_to_indexing_contract
      description: Tagging and ontology outputs feed library indexing and search structures.
      producers:
        - tagging_orchestrator_agent
        - ontology_linking_agent
      consumers:
        - library_indexing_agent
        - skill_library_agent
        - workflow_template_agent

    - id: governance_global_contract
      description: All outward-facing actions and persistent writes are subject to governance, risk, ethics, and compliance checks.
      producers:
        - all_agents
      consumers:
        - policy_enforcement_agent
        - risk_assessment_agent
        - ethics_review_agent
        - compliance_agent
        - governance_orchestrator

  execution_policies:
    - id: default_safe_mode
      description: >
        Any high-impact action (external side effects, memory writes, schema/code changes,
        or tool/library updates) must pass through memory governance + global governance.
      required_checkpoints:
        - memory_governance_orchestrator
        - governance_orchestrator

    - id: research_rigour_policy
      description: >
        Claims presented as factual must be backed by a research workflow including
        retrieval, credibility scoring, cross-verification, and uncertainty estimation.
      required_agents:
        - research_planning_agent
        - information_retrieval_agent
        - source_credibility_agent
        - cross_verification_agent
        - evidence_ranking_agent
        - uncertainty_estimation_agent
        - claim_validation_agent

    

```
