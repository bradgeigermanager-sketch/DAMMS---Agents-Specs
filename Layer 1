## 3. Message schemas (Python, Pydantic)

```python
# core/schemas.py
from enum import Enum
from typing import List, Dict, Any, Optional
from pydantic import BaseModel, Field
import uuid
import datetime as dt


class RiskLevel(str, Enum):
    LOW = "low"
    MEDIUM = "medium"
    HIGH = "high"


class Channel(str, Enum):
    UI = "ui"
    INTERNAL = "internal"
    EXTERNAL_API = "external_api"


class MessageType(str, Enum):
    USER_INPUT = "user_input"
    PLAN = "plan"
    TASK = "task"
    RESULT = "result"
    VALIDATION_REQUEST = "validation_request"
    VALIDATION_RESULT = "validation_result"
    GOVERNANCE_DECISION = "governance_decision"
    ERROR = "error"


class CausalTrace(BaseModel):
    trace_id: str = Field(default_factory=lambda: str(uuid.uuid4()))
    parent_id: Optional[str] = None
    span: Optional[str] = None
    created_at: dt.datetime = Field(default_factory=dt.datetime.utcnow)


class PolicyContext(BaseModel):
    risk_level: RiskLevel = RiskLevel.LOW
    high_risk_flags: List[str] = []
    policies: List[str] = []  # policy IDs or names


class AgentRef(BaseModel):
    id: str
    role: str
    domain: Optional[str] = None


class Message(BaseModel):
    id: str = Field(default_factory=lambda: str(uuid.uuid4()))
    type: MessageType
    source: AgentRef
    target: AgentRef
    channel: Channel = Channel.INTERNAL
    content: Dict[str, Any]
    policy_context: PolicyContext = PolicyContext()
    causal_trace: CausalTrace = CausalTrace()
    created_at: dt.datetime = Field(default_factory=dt.datetime.utcnow)


class ValidationResult(BaseModel):
    passed: bool
    reasons: List[str] = []
    risk_level: RiskLevel = RiskLevel.LOW
    suggested_modifications: Optional[Dict[str, Any]] = None
