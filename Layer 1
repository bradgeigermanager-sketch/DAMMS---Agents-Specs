# core/routing.py
from typing import Callable, Dict, Any
from core.schemas import Message, AgentRef, MessageType, Channel


class Router:
    def __init__(self, registry: Dict[str, Any]):
        """
        registry: {agent_id: agent_instance}
        """
        self.registry = registry

    async def send_to(self, msg: Message, target_id: str, new_type: MessageType) -> Message:
        target_agent = self.registry[target_id]
        new_msg = msg.copy(update={
            "type": new_type,
            "target": AgentRef(id=target_id, role=getattr(target_agent, "role", "unknown")),
        })
        handler: Callable = getattr(target_agent, "handle", None)
        if handler is None:
            raise RuntimeError(f"Agent {target_id} has no handle()")
        return await handler(new_msg)

    async def execute_plan(self, plan_msg: Message) -> Message:
        agent = self.registry["reasoning_manager"]
        return await agent.execute_plan(plan_msg)

    async def send_to_ui(self, msg: Message) -> Message:
        ui_agent = self.registry["ui_agent"]
        return await ui_agent.render(msg)
```

