## 4. Orchestrator runtime skeleton

```python
# agents/orchestrator.py
from typing import List
from core.schemas import Message, MessageType, RiskLevel, AgentRef
from core.routing import Router
from core.policies import PolicyEngine
from core.tracing import TraceLogger


class Orchestrator:
    def __init__(self, router: Router, policy_engine: PolicyEngine, trace_logger: TraceLogger):
        self.router = router
        self.policy_engine = policy_engine
        self.trace_logger = trace_logger

    async def handle_user_input(self, msg: Message) -> Message:
        self.trace_logger.start_span(msg.causal_trace, "orchestrator.handle_user_input")

        # 1. Classify risk
        policy_ctx = self.policy_engine.assess_risk(msg)
        msg.policy_context = policy_ctx

        # 2. Choose pipeline
        if policy_ctx.risk_level == RiskLevel.HIGH:
            return await self._high_risk_pipeline(msg)
        else:
            return await self._normal_pipeline(msg)

    async def _normal_pipeline(self, msg: Message) -> Message:
        # 1. Reasoning manager for plan
        plan_msg = await self.router.send_to(
            msg,
            target_id="reasoning_manager",
            new_type=MessageType.PLAN,
        )

        # 2. Execute plan via specialists/managers
        result_msg = await self.router.execute_plan(plan_msg)

        # 3. Light validation (fact-check + constraints)
        validated_msg = await self._run_validators(result_msg, validators=["fact_checker", "constraint_enforcer"])

        # 4. Return to UI
        return await self.router.send_to_ui(validated_msg)

    async def _high_risk_pipeline(self, msg: Message) -> Message:
        # 1. Safety manager pre-screen
        screened_msg = await self.router.send_to(
            msg,
            target_id="safety_manager",
            new_type=MessageType.TASK,
        )

        # 2. Reasoning manager for plan (under safety constraints)
        plan_msg = await self.router.send_to(
            screened_msg,
            target_id="reasoning_manager",
            new_type=MessageType.PLAN,
        )

        # 3. Execute plan
        result_msg = await self.router.execute_plan(plan_msg)

        # 4. Heavy validation: harm + legal + constraints + fact-check
        validated_msg = await self._run_validators(
            result_msg,
            validators=["harm_validator", "legal_validator", "constraint_enforcer", "fact_checker"],
        )

        # 5. Governance review if still high risk
        if validated_msg.policy_context.risk_level == RiskLevel.HIGH:
            gov_msg = await self.router.send_to(
                validated_msg,
                target_id="governance_manager",
                new_type=MessageType.GOVERNANCE_DECISION,
            )
            return await self.router.send_to_ui(gov_msg)

        return await self.router.send_to_ui(validated_msg)

    async def _run_validators(self, msg: Message, validators: List[str]) -> Message:
        current = msg
        for validator_id in validators:
            current = await self.router.send_to(
                current,
                target_id=validator_id,
                new_type=MessageType.VALIDATION_REQUEST,
            )
        return current
```

