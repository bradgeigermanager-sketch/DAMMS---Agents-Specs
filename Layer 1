### 3. Governance manager

```python
# agents/managers/governance.py
from core.schemas import Message, MessageType, AgentRef, RiskLevel


class GovernanceManager:
    role = "Manager"
    domain = "governance"

    def __init__(self, rules_engine, decision_store):
        """
        rules_engine: evaluates governance rules / escalation policies
        decision_store: persists governance decisions for audit
        """
        self.rules_engine = rules_engine
        self.decision_store = decision_store

    async def handle(self, msg: Message) -> Message:
        if msg.type != MessageType.GOVERNANCE_DECISION:
            raise ValueError(f"Unsupported message type: {msg.type}")

        decision = await self.rules_engine.evaluate(msg)
        await self.decision_store.save(msg, decision)

        # Optionally modify content or block it
        content = dict(msg.content)
        content["governance_decision"] = decision

        # If blocked, downgrade to safe explanation
        if decision.get("action") == "block":
            content["text"] = decision.get("user_message", "This content cannot be provided.")
            new_risk = RiskLevel.LOW
        else:
            new_risk = msg.policy_context.risk_level

        ctx = msg.policy_context.copy(update={"risk_level": new_risk})

        return msg.copy(update={
            "type": MessageType.RESULT,
            "content": content,
            "policy_context": ctx,
            "target": AgentRef(id="ui_agent", role="UI"),
        })
