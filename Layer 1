### 10. Tool/skills manager (optional but usually needed)

```python
# agents/managers/tools.py
from core.schemas import Message, MessageType


class ToolsManager:
    role = "Manager"
    domain = "tools"

    def __init__(self, tool_registry):
        """
        tool_registry: {tool_name: callable}
        """
        self.tool_registry = tool_registry

    async def handle(self, msg: Message) -> Message:
        if msg.type != MessageType.TASK:
            raise ValueError(f"Unsupported message type: {msg.type}")

        tool_name = msg.content.get("tool")
        args = msg.content.get("args", {})
        tool = self.tool_registry[tool_name]

        result = await tool(**args) if callable(tool) else None

        return msg.copy(update={
            "type": MessageType.RESULT,
            "content": {**msg.content, "tool_result": result},
        })
