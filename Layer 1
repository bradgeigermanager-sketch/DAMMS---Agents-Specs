### 4. Fact checker specialist

```python
# agents/specialists/fact_checker.py
from core.schemas import Message, MessageType, ValidationResult, RiskLevel


class FactChecker:
    role = "Specialist"
    domain = "validation"

    def __init__(self, checker_backend):
        """
        checker_backend: service that can verify claims and return evidence
        """
        self.checker_backend = checker_backend

    async def handle(self, msg: Message) -> Message:
        text = str(msg.content.get("text", ""))
        result = await self.checker_backend.check(text)

        passed = result.get("status") == "ok"
        reasons = result.get("issues", [])
        level = RiskLevel.LOW if passed else RiskLevel.MEDIUM

        vr = ValidationResult(
            passed=passed,
            reasons=reasons,
            risk_level=level,
            suggested_modifications=result.get("suggested_modifications"),
        )

        ctx = msg.policy_context.copy(update={"risk_level": max(ctx_level(level, msg.policy_context.risk_level), level)})

        return msg.copy(update={
            "type": MessageType.VALIDATION_RESULT,
            "content": {**msg.content, "fact_check": vr.dict(), "evidence": result.get("evidence", [])},
            "policy_context": ctx,
        })


def ctx_level(a: RiskLevel, b: RiskLevel) -> RiskLevel:
    order = [RiskLevel.LOW, RiskLevel.MEDIUM, RiskLevel.HIGH]
    return max(a, b, key=lambda x: order.index(x))
```

