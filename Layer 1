from core.schemas import Message, PolicyContext, RiskLevel


class PolicyEngine:
    def __init__(self, config: dict):
        self.config = config

    def assess_risk(self, msg: Message) -> PolicyContext:
        text = str(msg.content.get("text", "")).lower()
        flags = []

        # toy heuristic; in your system this maps to DAMMS risk manifolds
        if any(k in text for k in ["suicide", "kill", "bomb", "exploit"]):
            flags.append("self_harm_or_violence")
        if any(k in text for k in ["credit card", "ssn", "password"]):
            flags.append("sensitive_personal_data")

        if flags:
            level = RiskLevel.HIGH
        else:
            level = RiskLevel.LOW

        return PolicyContext(
            risk_level=level,
            high_risk_flags=flags,
            policies=["global_safety_policy_v1"],
        )
