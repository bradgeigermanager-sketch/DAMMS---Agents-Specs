        policy_engine: decides what can be stored, retained, or deleted
        """
        self.memory_store = memory_store
        self.policy_engine = policy_engine

    async def handle(self, msg: Message) -> Message:
        action = msg.content.get("memory_action")
        if action == "store":
            return await self._store(msg)
        if action == "retrieve":
            return await self._retrieve(msg)
        if action == "delete":
            return await self._delete(msg)
        raise ValueError(f"Unsupported memory_action: {action}")

    async def _store(self, msg: Message) -> Message:
        decision = self.policy_engine.decide_store(msg)
        if not decision.get("allowed", True):
            return msg.copy(update={
                "type": MessageType.RESULT,
                "content": {**msg.content, "memory_store": "denied", "reason": decision.get("reason")},
            })

        key = await self.memory_store.store(msg.content.get("memory_payload"))
        return msg.copy(update={
            "type": MessageType.RESULT,
            "content": {**msg.content, "memory_store": "ok", "memory_key": key},
        })

    async def _retrieve(self, msg: Message) -> Message:
        key = msg.content.get("memory_key")
        data = await self.memory_store.retrieve(key)
        return msg.copy(update={
            "type": MessageType.RESULT,
            "content": {**msg.content, "memory_data": data},
        })

    async def _delete(self, msg: Message) -> Message:
        key = msg.content.get("memory_key")
        await self.memory_store.delete(key)
        return msg.copy(update={
            "type": MessageType.RESULT,
            "content": {**msg.content, "memory_delete": "ok"},
        })
```

