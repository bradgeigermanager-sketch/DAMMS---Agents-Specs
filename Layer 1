from core.schemas import Message, MessageType, AgentRef


class KnowledgeManager:
    role = "Manager"
    domain = "knowledge"

    def __init__(self, retriever, auditor):
        """
        retriever: abstraction over vector DB / search / tools
        auditor: knowledge audit component (e.g., checks freshness, conflicts)
        """
        self.retriever = retriever
        self.auditor = auditor

    async def handle(self, msg: Message) -> Message:
        if msg.type == MessageType.TASK:
            return await self._answer_question(msg)
        raise ValueError(f"Unsupported message type: {msg.type}")

    async def _answer_question(self, msg: Message) -> Message:
        query = msg.content.get("text") or msg.content.get("query")
        results = await self.retriever.search(query)
        audited = await self.auditor.audit(results)

        return msg.copy(update={
            "type": MessageType.RESULT,
            "content": {
                **msg.content,
                "answer": audited.get("answer"),
                "sources": audited.get("sources", []),
                "knowledge_audit": audited,
            },
            "target": AgentRef(id="orchestrator", role="Orchestrator"),
        })
